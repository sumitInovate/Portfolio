# CodeAether Environment Configuration
# Copy this file to .env and fill in your actual values.
# Current mode: frontend-only runtime (localStorage + client-side Gemini).

# Gemini API key used by client-side profile/avatar/mission agents.
# WARNING: VITE_* variables are bundled into frontend code.
# Use this for development/frontend-only mode.
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# JWT secret for local auth token signing in AuthContext
VITE_JWT_SECRET=change_this_in_production

# WhatsApp contact form integration (optional in local dev)
VITE_MY_WHATSAPP_NUMBER=91XXXXXXXXXX
VITE_CALLMEBOT_API_KEY=your_callmebot_key

# Application Mode
# Options: 'development', 'production', 'staging'
VITE_APP_MODE=development
