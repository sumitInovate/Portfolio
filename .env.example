# CodeAether Environment Configuration
# Copy this file to .env and fill in your actual values.
# Registration and training agents now run through server-side API routes.

# Server-side Gemini API key
# Required by:
#   - api/agent/run.js
#   - api/ai/generate-profile.js
#   - api/ai/generate-avatar.js
GEMINI_API_KEY=your_gemini_api_key_here

# Backend API Configuration (for future ASP .NET integration)
# When true, all data operations will call backend API instead of localStorage
# When false, uses localStorage (development/testing mode)
VITE_USE_BACKEND_API=false

# Optional API base URL when the frontend and API routes run on different origins.
# Leave blank for same-origin deployments.
# Example local setup: VITE_API_URL=http://localhost:3000 while the frontend runs on :5173
VITE_API_URL=http://localhost:5000

# Application Mode
# Options: 'development', 'production', 'staging'
VITE_APP_MODE=development
